generator client {
  provider = "prisma-client-js"
  // We set a custom output earlier; keep it or remove it.
  // If we keep it, we'll import from "src/generated/prisma".
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ListingCategory {
  BOOKS
  ELECTRONICS
  FURNITURE
  CLOTHING
  SPORTS
  MUSICAL_INSTRUMENTS
  OTHER
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  DELETED
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  name     String?
  role     Role      @default(USER)
  listings Listing[] // one-to-many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Listing {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  priceCents  Int? // store price in cents
  category    ListingCategory @default(OTHER)
  condition   ListingCondition @default(GOOD)
  status      ListingStatus   @default(ACTIVE)
  location    String? // campus location or building
  images      String? // JSON array of image URLs
  tags        String? // JSON array of tags
  
  sellerId    Int
  seller      User    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}
