generator client {
  provider = "prisma-client-js"
  // We set a custom output earlier; keep it or remove it.
  // If we keep it, we'll import from "src/generated/prisma".
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum ContactPreference {
  EMAIL
  PHONE
  BOTH
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  name        String?
  phoneNumber String?
  role        Role      @default(USER)
  listings    Listing[] // one-to-many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Listing {
  id                Int               @id @default(autoincrement())
  title             String
  description       String?
  priceCents        Int? // store price in cents
  condition         Condition
  contactPreference ContactPreference @default(EMAIL)
  sellerId          Int
  seller            User              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  photos            Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
}

model Photo {
  id        Int     @id @default(autoincrement())
  url       String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
}
